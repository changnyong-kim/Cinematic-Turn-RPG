  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Timeline / Cinemachine \uAE30\uBC18\uC758\n\uC2DC\uB124\uB9C8\uD2F1 \uD134\uC81C
    \uC804\uD22C \uD3EC\uD2B8\uD3F4\uB9AC\uC624\uC785\uB2C8\uB2E4.\n\nModel / Controller
    / ViewModel / View / CinematicDirector\uB85C \uC5ED\uD560\uC744 \uB098\uB204\uACE0,\n\uC804\uD22C
    \uB85C\uC9C1, UI \uAC31\uC2E0, \uC2DC\uB124\uB9C8\uD2F1 \uC5F0\uCD9C\uC774 \uC11C\uB85C
    \uC9C1\uC811 \uC758\uC874\uD558\uC9C0 \uC54A\uB3C4\uB85D \uAD6C\uC131\uD588\uC2B5\uB2C8\uB2E4.\n\nBattleModel\n-
    \uC804\uD22C \uC0C1\uD0DC, HP, \uACF5\uACA9 \uACB0\uACFC, \uD328\uB9C1 \uD310\uC815
    \uAD00\uB9AC\n- UI\uC640 \uC5F0\uCD9C\uC744 \uBAA8\uB974\uB294 \uC21C\uC218 \uC804\uD22C
    \uADDC\uCE59 \uB2F4\uB2F9\n\nBattleController\n- \uC785\uB825 \uCC98\uB9AC, \uD134
    \uC9C4\uD589, \uC804\uD22C \uACB0\uACFC \uC801\uC6A9\n- Model \uACB0\uACFC\uB97C
    \uAE30\uC900\uC73C\uB85C UI\uC640 \uC5F0\uCD9C \uD750\uB984 \uC870\uC728\n\nBattleCinematicDirector\n-
    Timeline \uAE30\uBC18 \uACF5\uACA9, \uD53C\uACA9, \uD328\uB9C1, \uBC18\uACA9
    \uC5F0\uCD9C \uC81C\uC5B4\n- Signal\uB85C \uD310\uC815 \uD0C0\uC774\uBC0D\uACFC
    \uC5F0\uCD9C \uC885\uB8CC \uC2DC\uC810\uC744 \uB3D9\uAE30\uD654\n\nBattleViewModel
    / UIBattleView\n- UI \uD45C\uC2DC \uB370\uC774\uD130\uC640 \uC2E4\uC81C UI \uCEF4\uD3EC\uB10C\uD2B8
    \uAC31\uC2E0 \uBD84\uB9AC\n- Controller\uAC00 UI \uCEF4\uD3EC\uB10C\uD2B8\uB97C
    \uC9C1\uC811 \uCC38\uC870\uD558\uC9C0 \uC54A\uB3C4\uB85D \uAD6C\uC131"
